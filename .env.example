# pss-assembly-viewer reads its runtime env from ../platform-portal/.env
# (the canonical location — keep secrets in one place).
#
# This file documents ONLY the variables specific to this app, or values
# that might reasonably differ from the gateway defaults. Copy to .env.local
# next to docker-compose.app.yml if you need per-host overrides.

# Internal URL of the doc service — reachable from inside the container.
# Default is the Pi's gateway at 10.0.0.75:80; change for dev / other hosts.
# DOC_SERVICE_URL=http://10.0.0.75:80

# Tag to deploy. Leave unset for :latest; pin to a git SHA for rollback.
# IMAGE_TAG=abc1234

# ── All NEXT_PUBLIC_* / Supabase keys come from ../platform-portal/.env ──
# If you need to override one here for a specific deploy, uncomment:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_DOC_GATEWAY_BASE_URL=
# NEXT_PUBLIC_APP_URL=
# NEXT_PUBLIC_DOC_SERVICE_URL=
